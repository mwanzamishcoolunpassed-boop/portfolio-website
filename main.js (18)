// Menu button (three dots) toggle
function toggleMenu() {
    const menuOptions = document.getElementById('menuOptions');
    menuOptions.style.display = menuOptions.style.display === 'block' ? 'none' : 'block';
}

// Show WhatsApp Link on Top
function showWhatsAppLink() {
    // Show the WhatsApp message on top
    document.getElementById('whatsappMessage').style.display = 'block';
    setTimeout(() => {
        document.getElementById('whatsappMessage').style.display = 'none'; // Hide after 5 seconds
    }, 5000);
}



